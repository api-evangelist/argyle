{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/argyle/refs/heads/main/json-schema/filingstatus.json",
  "title": "FilingStatus",
  "type": "object",
  "properties": {
    "type": {
      "type": "string",
      "enum": [
        "federal",
        "state",
        "local"
      ],
      "description": "Tax authority.\n- `federal`\n- `state`\n- `local`\n"
    },
    "location": {
      "type": "string",
      "description": "Local jurisdiction. Values depend on `type`.\n- if type is `federal` \u2014 `null`\n- if type is `state` \u2014 state abbreviation code\n- if type is `local` \u2014 city name or area code\n"
    },
    "status": {
      "type": "string",
      "description": "Marital status."
    }
  }
}